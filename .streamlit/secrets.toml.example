# Streamlit Cloud / 로컬 secrets.toml 템플릿
# 로컬: secrets.toml.example → .streamlit/secrets.toml
# Cloud: Settings → Secrets — docs/DEPLOY_STREAMLIT_CLOUD.md 또는 secrets.cloud.toml 참고

# --- Upstage (권장) ---
UPSTAGE_API_KEY = ""
UPSTAGE_MODEL = "solar-pro3"
LLM_PROVIDER = "upstage"

# --- Gemini (폴백) ---
# GEMINI_API_KEY = ""
# GEMINI_MODEL = "gemini-2.5-flash"

# --- Supabase — 숲 모듈 클라우드 이중 저장 ---
# Dashboard → Project Settings → API
#   url  = Project URL
#   key  = publishable (sb_publishable_...) 또는 secret (sb_secret_...) — Dashboard → API Keys
[supabase]
url = ""
key = ""

# 로컬 .env 대안 (평면 키):
# SUPABASE_URL = ""
# SUPABASE_KEY = ""

# --- Google Sheets (숲 모듈 미사용, 선택) ---
# GOOGLE_SHEET_ID = ""

# 추가 문의 수신 (기본 hyc6999@gmail.com 은 앱에 내장)
# INQUIRY_EMAIL = "lab@example.com"

# Google 서비스 계정 (Sheets용, 선택)
# [gcp_service_account]
# type = "service_account"
# project_id = "your-project"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "xxx@xxx.iam.gserviceaccount.com"
