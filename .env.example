# 로컬 전용 — 이 파일을 복사해 .env 로 저장하세요 (Git에 커밋 금지)
# Streamlit Cloud 배포 시에는 Settings → Secrets 에 동일 키를 넣으세요.

GEMINI_API_KEY=your_gemini_api_key_here
# gemini-1.5-flash 는 일부 API 키에서 404 — 기본값 gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_SHEET_ID=your_google_sheet_id_here
# INQUIRY_EMAIL=optional@example.com
