# 로컬 전용 — 이 파일을 복사해 .env 로 저장하세요 (Git에 커밋 금지)
# Streamlit Cloud 배포 시에는 Settings → Secrets 에 동일 키를 넣으세요.

# --- dlinso v2: Upstage Solar (권장) ---
UPSTAGE_API_KEY=your_upstage_api_key_here
UPSTAGE_MODEL=solar-pro3
LLM_PROVIDER=upstage

# SQLite (기본: data/dlinso.db)
# DATABASE_PATH=data/dlinso.db

# 숲 · 연결의 서사 — 로컬 SQLite + Supabase 클라우드 동기화
# DB 경로 — 상대 경로 권장 (Cloud·로컬 공통). Windows 절대 경로는 Cloud에서 자동 폴백.
# DATABASE_PATH=data/dlinso.db
ISOLATION_DATABASE_PATH=data/isolation.db

# Supabase (숲 · 여정 · 학습 — Streamlit Cloud 영속 저장)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your_service_role_key_here

# --- Gemini (마이그레이션 중 폴백) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Google Sheets (로컬 SQLite 전용 모드 — 숲 모듈은 미사용)
# GOOGLE_SHEET_ID=your_google_sheet_id_here
# 로컬: service_account.json · Cloud: st.secrets[gcp_service_account]
# INQUIRY_EMAIL=optional@example.com
